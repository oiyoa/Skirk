# Copy to `.env` next to docker-compose.yml. All values are optional —
# defaults are sensible for the headless exit mode.

# ---- General ----------------------------------------------------------------

# Container timezone (uses the IANA tz database baked into distroless).
TZ=UTC

# ---- OAuth (runtime overrides for the client baked at build time) -----------
# Release images ship with these embedded via ldflags; set them only if you
# need to override or if your image was built without credentials.
#
# SKIRK_OAUTH_CLIENT_ID=
# SKIRK_OAUTH_CLIENT_SECRET=
#
# Setup OAuth flow: "desktop" (default — browser + paste-the-URL fallback)
# SKIRK_OAUTH_FLOW=desktop
#
# Short-circuit the refresh-token flow with a pre-fetched bearer token
# (Source=env). Mostly useful for testing.
# SKIRK_ACCESS_TOKEN=

# ---- Mailbox janitor (Drive cleanup) ----------------------------------------
# Skip the janitor entirely (boolean: 1/true/yes/on).
# SKIRK_DISABLE_JANITOR=0
#
# How old an object must be before the janitor will delete it. Default 2h.
# SKIRK_JANITOR_OLDER_THAN=2h
#
# How often the janitor sweeps. Default 15m.
# SKIRK_JANITOR_INTERVAL=15m
#
# Cap on deletions per prefix per sweep (prevents quota spikes). Default 200.
# SKIRK_JANITOR_MAX_DELETES_PER_PREFIX=200
#
# Pause between individual delete calls (Go duration). Default 100ms.
# SKIRK_JANITOR_DELETE_DELAY=100ms

# ---- Drive quota logging ----------------------------------------------------
# Interval for periodic Drive-quota usage logs. "off"/"0"/"false" disables.
# SKIRK_QUOTA_LOG_INTERVAL=5m

# ---- Tunnel observability ---------------------------------------------------
# Enable extra tunnel telemetry / debug logging (boolean).
# SKIRK_OBSERVE=0

# ---- Client (serve-client) host port mappings -------------------------------
# Host-side ports for the `client` profile. Default is to publish on all
# interfaces; prefix with `127.0.0.1:` to bind loopback-only.
# SKIRK_SOCKS_PROXY_PORT=18080
# SKIRK_HTTP_PROXY_PORT=18081
